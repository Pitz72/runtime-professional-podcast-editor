{
  "name": "runtime-radio-podcast-toolkit",
  "private": true,
  "version": "0.0.3",
  "main": "dist/main/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json -w\" \"wait-on tcp:5173 && wait-on dist/main/main.cjs && electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:app": "electron-builder --win",
    "build": "npm run build:renderer && npm run build:main && npm run build:app",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "lamejs": "^1.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.2.0",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.runtimeradio.podcast-toolkit",
    "productName": "Runtime Radio Podcast Toolkit",
    "directories": {
      "output": "builds/0.0.3"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Runtime Radio Podcast Toolkit"
    }
  }
}